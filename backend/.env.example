# ============================================================
#  School Task Management — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend (for CORS whitelist) ─────────────────────────
FRONTEND_URL=http://localhost:5173

# ── MySQL Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_taskdb
DB_USER=school_user
DB_PASSWORD=school_password

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_strong_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP (Nodemailer — email alerts) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── File Uploads ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Sequelize (used by sequelize-cli migrations) ───────────
# These mirror DB_* above — sequelize-cli reads from config/config.js
# which already imports these, so no duplication needed.
